# Supabase — get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL — set this in Vercel env vars (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Admin access — set both in Vercel env vars (and .env.local for local dev)
# Generate ADMIN_SESSION_TOKEN with: openssl rand -hex 32
ADMIN_PASSWORD=your-admin-password-here
ADMIN_SESSION_TOKEN=your-random-secret-token-here
